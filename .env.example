# PostgreSQL
POSTGRES_USER=tradetracker
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=tradetracker_db

# Database URL (for SQLAlchemy async + Alembic)
DATABASE_URL=postgresql+asyncpg://tradetracker:your_secure_password_here@db:5432/tradetracker_db

# JWT Authentication
SECRET_KEY=your_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
